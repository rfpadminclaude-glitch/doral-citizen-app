# ============================================================================
# Doral Citizen App — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# From https://app.supabase.com/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
# For local CLI (supabase db push) — get from `supabase status` or project settings → Database
SUPABASE_DB_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- LLM providers ----------------------------------------------------------
# Groq: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash-exp

# Embeddings (Google text-embedding-004 via Gemini API — free tier)
EMBED_API_KEY=${GEMINI_API_KEY}
EMBED_MODEL=text-embedding-004
EMBED_DIMENSIONS=768

# --- Twilio (SMS) -----------------------------------------------------------
# Trial credentials: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15555555555
# Comma-separated list of pre-verified phone numbers for trial SMS sends
TWILIO_VERIFIED_NUMBERS=+15555555555,+15555555556

# --- App config -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es

# --- Demo flags -------------------------------------------------------------
# Set to true to force Groq calls to fail so the Gemini fallback can be demoed
DEMO_FORCE_GROQ_FAIL=false
